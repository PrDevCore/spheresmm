# ═══════════════════════════════════════════════════════════
# SphereSMM SaaS Dashboard — Production Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to `.env.local` and fill in your values.
# DO NOT commit .env.local to version control (it's in .gitignore).
# ═══════════════════════════════════════════════════════════

# ─── SERVER-SIDE (process.env) ────────────────────────────

# GEMINI_API_KEY: Required for AI caption generation via Google Gemini API.
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The public URL where this app is hosted (used for OAuth redirects).
# In production: "https://yourdomain.com"
# Locally:       "http://localhost:3000"
APP_URL="http://localhost:3000"

# LinkedIn API requires a version header in YYYYMM format.
# Default: 202606 (June 2026)
LINKEDIN_VERSION="202606"

# ─── CLIENT-SIDE (import.meta.env / VITE_ prefix) ─────────
# These are embedded in the browser bundle at build time.

# Firebase Configuration — from your Firebase project settings
# Console: https://console.firebase.google.com → Project Settings → Web App
VITE_FIREBASE_API_KEY="AIzaSyCgRBe_LCHmKnNQ6wRjzleF0tPN9-K_uUo"
VITE_FIREBASE_AUTH_DOMAIN="spheresmm-saas-dashboard.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="spheresmm-saas-dashboard"
VITE_FIREBASE_APP_ID="1:1067846145797:web:ae2b58c1c95b1348e3096c"
VITE_FIREBASE_MESSAGING_SENDER_ID="1067846145797"
VITE_FIREBASE_STORAGE_BUCKET="spheresmm-saas-dashboard.firebasestorage.app"
# Optional: custom Firestore database ID (omit for "(default)")
VITE_FIRESTORE_DATABASE_ID="ai-studio-spheresmmsaasdas-5b0a4170-6cfc-41b1-847f-5ff713984036"

# Meta App ID for client-side OAuth (response_type=token flow).
# Create a Meta App at: https://developers.facebook.com
# Required for: Facebook Page publishing, Instagram Business publishing
# Setup steps:
#   1. Create a Meta App → Add "Facebook Login" product
#   2. Settings → Valid OAuth Redirect URIs: https://yourdomain.com/oauth/callback
#   3. Under "Facebook Login" → Quickstart → set OAuth redirect
VITE_META_APP_ID="YOUR_META_APP_ID"

# ─── OPTIONAL (Dev Only) ───────────────────────────────────

# DISABLE_HMR: Set to "true" to disable Hot Module Replacement and file watching.
# Used by AI Studio / agent-based editing to prevent flickering.
# DISABLE_HMR="true"